# Festayre, variables d'environnement.
# Copier vers .env.local (jamais commite) et remplir.
# SANS ces variables l'app tourne quand meme en mode invite
# (carte, toilettes, programme) : seuls compte et Festayre+ sont off.

# --- Supabase (comptes + favoris) ------------------------------------
# Dashboard > Settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Cle ADMIN, serveur uniquement (webhook Stripe). Ne jamais prefixer
# par NEXT_PUBLIC_, ne jamais exposer au navigateur.
SUPABASE_SERVICE_ROLE_KEY=

# --- Stripe (pack Festayre+) ------------------------------------------
# Dashboard > Developers > API keys
STRIPE_SECRET_KEY=
# Price ID du produit "Festayre+" (paiement unique), ex : price_xxx
STRIPE_PRICE_FESTAYRE_PLUS=
# Dashboard > Developers > Webhooks > endpoint /api/stripe/webhook
STRIPE_WEBHOOK_SECRET=

# --- PostHog (analytics produit, host UE) ------------------------------
# https://eu.posthog.com > Settings > Project > Project API key
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# --- Sentry (monitoring erreurs) ---------------------------------------
# https://sentry.io > Settings > Projects > [projet] > Client Keys (DSN)
NEXT_PUBLIC_SENTRY_DSN=
